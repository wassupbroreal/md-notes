{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "MD Notes",
    "version": "1.0.0",
    "identifier": "com.mdnotes.app",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "MD Notes",
                "width": 1000,
                "height": 700,
                "minWidth": 700,
                "minHeight": 500,
                "decorations": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "nsis"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}